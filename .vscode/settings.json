{
  "editor.wordWrap": "on",
  "[markdown]": {
    "editor.formatOnSave": false,
    "editor.quickSuggestions": {
      "other": "on",
      "comments": "off",
      "strings": "off"
    }
  },
"markdown-preview-enhanced.previewTheme": "github-light.css",
"markdown-preview-enhanced.codeBlockTheme": "github.css",
"markdown-preview-enhanced.enableScriptExecution": true,
"cSpell.words": [
    "Munchkin",
    "LaunchPoint",
    "mcpServers",
    "BEGINTABS",
    "ENDTABS",
    "BEGINSHADEBOX",
    "ENDSHADEBOX",
    "MORELIKETHIS",
    "UICONTROL",
    "DONOTLOCALIZE",
    "CONTEXTUALHELP",
    "exl"
  ],
  "markdownlint.customRules": [
    "{adobeexl.adobe-markdown-authoring}/markdownlint-custom-rules/rules.js"
  ],
  "markdownlint.config": {
    "line-length": false,
    "AM001": false,
    "AM009": false,
    "AM011": false,
    "MD003": {
      "style": "atx"
    },
    "MD004": {
      "style": "consistent"
    },
    "MD007": {
      "indent": 4
    },
    "MD009": false,
    "MD012": false,
    "MD014": false,
    "MD024": false,
    "MD025": {
      "front_matter_title": ""
    },
    "MD026": false,
    "MD027": false,
    "MD028": false,
    "MD030": {
      "ul_multi": 3,
      "ol_multi": 2
    },
    "MD033": {
      "allowed_elements": [
        "a",
        "b",
        "br",
        "caption",
        "code",
        "col",
        "colgroup",
        "div",
        "em",
        "I",
        "img",
        "li",
        "ol",
        "p",
        "pre",
        "s",
        "span",
        "strong",
        "sub",
        "sup",
        "table",
        "tbody",
        "td",
        "tfoot",
        "th",
        "thead",
        "tr",
        "u",
        "ul"
      ]
    },
    "MD036": false,
    "MD038": false,
    "MD039": false,
    "MD040": false,
    "MD045": false
  }
}
